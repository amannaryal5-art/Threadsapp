PORT=5000
NODE_ENV=development
PLATFORM_NAME=ThreadsApp
FRONTEND_URL=http://localhost:3001
ADMIN_URL=http://localhost:3000
CORS_ORIGINS=
ALLOW_VERCEL_PREVIEWS=false

# DATABASE (PostgreSQL)
# =============================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=threads
DB_SYNC=false
DB_LOGGING=false

# Optional: instead of the DB_* fields above, you can use a full connection string.
DATABASE_URL=

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

FREE_SHIPPING_THRESHOLD=499
GST_RATE=0.18

RAZORPAY_KEY_ID=rzp_live_key_here
RAZORPAY_KEY_SECRET=rzp_live_secret_here
RAZORPAY_WEBHOOK_SECRET=replace-with-your-razorpay-webhook-secret

EMAIL_PROVIDER=smtp
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=ThreadsApp <you@gmail.com>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_TLS_REJECT_UNAUTHORIZED=false
EMAIL_CONNECTION_TIMEOUT_MS=10000
EMAIL_GREETING_TIMEOUT_MS=10000
EMAIL_SOCKET_TIMEOUT_MS=15000
EMAIL_HTTP_TIMEOUT_MS=10000
