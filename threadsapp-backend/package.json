  "version": "1.0.0",
  "description": "Production-ready REST API backend for ThreadsApp fashion ecommerce platform",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "start:dev": "nodemon server.js",
